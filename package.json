{
  "name": "BPN-Shopify-Theme-Development",
  "version": "1.0.0",
  "description": "Bare Performance Nutrition Shopify theme development tool.",
  "private": true,
  "main": "webpack.config.js",
  "engines": {
    "node": ">=18.20.0",
    "npm": ">=8.0.0"
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "scripts": {
    "check-version": "node check-node-version.js",
    "preinstall": "npm run check-version",
    "prepare": "husky install",
    "build": "npm run check-version && webpack",
    "deploy": "./bin/deploy",
    "start": "npm run check-version && NODE_ENV=development webpack --watch",
    "dev": "npm run start",
    "create-dev-theme": "./bin/create-dev-theme",
    "eslint": "eslint 'src/js/**'",
    "stylelint": "stylelint '**/*.scss'",
    "theme-check": "shopify theme check --config .theme-check.yml",
    "lint": "npm run check-version && npm run eslint && npm run stylelint",
    "lint:all": "npm run check-version && npm run eslint && npm run stylelint && npm run theme-check",
    "sync:production": "bin/sync-production-settings"
  },
  "eslintConfig": {
    "parser": "vue-eslint-parser",
    "extends": [
      "plugin:vue/vue3-recommended",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/js/**/*.{js,vue}": [
      "eslint --fix"
    ],
    "src/styles/new/**/*.scss": [
      "stylelint --fix"
    ]
  },
  "keywords": [
    "shopify",
    "theme",
    "webpack"
  ],
  "author": "org:Bare-Performance-Nutrition",
  "contributors": [
    "@ds675",
    "@brianpurkiss",
    "@unscripter"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bare-Performance-Nutrition/bpn-shopify.git"
  },
  "dependencies": {
    "@thebeyondgroup/shopify-rich-text-renderer": "^2.1.0",
    "axios": "^0.26.0",
    "bootstrap": "4.6.0",
    "lazysizes": "^5.3.2",
    "micromodal": "^0.4.10",
    "moment": "^2.29.4",
    "swiper": "^8.1.3",
    "url": "^0.11.0",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.1.1",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.9.0",
    "@babel/eslint-parser": "^7.26.10",
    "@babel/plugin-transform-runtime": "^7.9.0",
    "@babel/preset-env": "^7.9.0",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/eslint-config-standard": "^9.0.0",
    "accoutrement": "^3.0.1",
    "autoprefixer": "^10.4.4",
    "babel-loader": "^8.1.0",
    "browser-sync": "^2.27.9",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^6.7.1",
    "dotenv": "^16.0.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "fs": "^0.0.1-security",
    "glob": "^7.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "mini-css-extract-plugin": "^2.6.0",
    "node-sass": "^7.0.1",
    "postcss-loader": "^6.2.1",
    "pre-commit": "^1.2.2",
    "prettier": "^3.5.3",
    "sass": "^1.99.0",
    "sass-loader": "^12.6.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^6.11.1",
    "vue-loader": "^17.4.2",
    "webpack": "^5.70.0",
    "webpack-cli": "^6.0.1",
    "webpack-shell-plugin-next": "^2.2.2"
  }
}
