{# required: product and subscription #}
<div class="og-reactivate-subscription">
  <button
    class="og-button og-action-button"
    data-click-target="og-reactivate-dialog-{{ subscription.public_id }}"
    @click="{{ 'SMDialog.open' | js }}"
  >
    {{ 'subscription_reactivate_button' | t }}
  </button>
  <sm-dialog id="og-reactivate-dialog-{{ subscription.public_id }}">
    <dialog>
      <form
        action="{{ 'reactivate_subscription' | action }}"
        @success="{{ 'SMDialog.close' | js }}"
        @reset="{{ 'SMDialog.close' | js }}"
      >
        {% set dialog_header_text = 'modal_subscription_reactivate_header' | t %}
        {% include 'dialog-header' %}
        <div class="og-dialog-body">
          <input type="hidden" name="subscription" value="{{ subscription.public_id }}">
          <input type="hidden" name="every" value="{{ subscription.every }}">
          <input type="hidden" name="every_period" value="{{ subscription.every_period }}">
          <p>
            {{ 'modal_subscription_reactivate_body' | t }}
          </p>
          <div class="og-reactivate-frequency">
            {{ 'item_controls_sending' | t }}
            <span>{{ subscription.quantity }}</span>
            {{ 'item_controls_every' | t }}

            <div class="og-select-wrapper">
<select
  name="frequency"
  id="frequency-select-reactivate-{{ subscription.public_id }}"
  aria-label="{{ 'a11y_frequency_select' | t }}"
>
  {# Get frequencies from settings, or fall back to defaults #}
  {% for frequency in 'frequencies' | setting([{every:1,period:1},{every:2,period:2},{every:4,period:2}]) %}
    {% set frequency_days = frequency.every * frequency.period %}

    {# Adjust skip logic based on product.external_product_id #}
    {% if product.external_product_id == 12686486854 %}
      {# Skip frequencies with 30 days and 45 days for this specific product ID #}
      {% if frequency_days != 30 and frequency_days != 45 %}
        {% set frequency_text = 'frequency_period' | t(every = frequency.every, period = frequency.period) %}
        {% if frequency.every == subscription.every and frequency.period == subscription.every_period %}
          <option selected value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% else %}
          <option value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% endif %}
      {% endif %}
    {% else %}
      {# Skip frequencies with 75 days and 90 days for all other products #}
      {% if frequency_days != 75 and frequency_days != 90 %}
        {% set frequency_text = 'frequency_period' | t(every = frequency.every, period = frequency.period) %}
        {% if frequency.every == subscription.every and frequency.period == subscription.every_period %}
          <option selected value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% else %}
          <option value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}
</select>

            </div>
          </div>

          <div class="og-new-orders-list">
            <div class="og-new-order-date">
              <div class="flex-row og-order-item-content">
                <div class="og-thumbnail og-dark-background">
                  <img src="{{ product.image_url }}" alt="" onerror="this.style.display='none';">
                </div>
                <div class="flex-column">
                  <h2 class="og-product-title-sm">{{ product.name }}</h2>
                  <dl>
                    <dt>{{ 'modal_subscription_reactivate_start_date' | t }}</dt>
                    <dd>
                      <sm-datepicker data-min-date-offset-days="2">
                        <button
                          id="select-start-date-trigger-{{ subscription.public_id }}"
                          data-variant="tertiary"
                          class="og-button og-order-date og-trigger"
                          data-datepicker-trigger
                          data-reflect-date
                        >
                          <span class="visually-hidden">{{ 'a11y_select_start_date_trigger' | t }}</span>
                          <svg width="18" height="18">
                            <use href="#calendar"></use>
                          </svg>
                        </button>
                        {% include 'datepicker-popover' %}
                        <input
                          type="hidden"
                          data-datepicker-input
                          name="start_date"
                          required
                        >
                      </sm-datepicker>
                    </dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="og-dialog-footer">
          <input type="hidden" required name="subscription" value="{{subscription.public_id}}">
          <button class="og-button" data-variant="tertiary" type="button" @click="{{ 'SMDialog.close' | js }}">
            {{ 'cancel_button' | t }}
          </button>
          <button class="og-button" type="submit" name="send_now">
            {{ 'modal_subscription_reactivate_save' | t }}
          </button>
        </div>
      </form>
    </dialog>
  </sm-dialog>
</div>
