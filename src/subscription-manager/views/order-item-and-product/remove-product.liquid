<div class="og-remove-product-control">
  <button
    class="og-button"
    data-variant="tertiary"
    @click="{{ '() => SMDialog.open("og-delete-dialog-" + order_item.public_id)' | js }}"
  >
    {{ 'delete_item_control_label' | t }}
  </button>
  <sm-dialog id="og-delete-dialog-{{ order_item.public_id }}">
    <dialog>
      <form
        action="{{ 'delete_item' | action }}"
        @success="{{ 'SMDialog.close' | js }}"
        @reset="{{ 'SMDialog.close' | js }}"
      >
        {% set dialog_header_text = 'modal_delete_item_header' | t %}
        {% include 'dialog-header' %}

        <div class="og-dialog-body">
          <p>{{ 'modal_delete_one_time_item_body' | t }}</p>
        </div>
        <div class="og-dialog-footer">
          <input type="hidden" value="{{ order_item.public_id }}" name="item">
          <button class="og-button" data-variant="tertiary" type="button" @click="{{ 'SMDialog.close' | js }}">
            {{ 'cancel_button' | t }}
          </button>
          <button class="og-button" data-variant="danger" type="submit" name="skip_shipment">
            {{ 'modal_delete_item_save' | t }}
          </button>
        </div>
      </form>
    </dialog>
  </sm-dialog>
</div>
