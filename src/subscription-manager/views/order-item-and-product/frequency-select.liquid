<form
  action="{{ 'change_subscription_frequency' | action }}"
  @finally="{{ 'enableFormElements' | js }}"
  @submit="{{ 'disableFormElements' | js }}"
>
     <label for="frequency-select-{{ order_item.public_id }}">
     Frequency
    </label>
  <div class="og-select-wrapper">
<select
  name="frequency"
  id="frequency-select-{{ order_item.public_id }}"
  aria-label="{{ 'a11y_frequency_select' | t }}"
  @change="{{ 'submitFormOnchange' | js }}"
>
  {% set subscription_frequency_still_exists = false %}
  
  {# Get frequencies from settings, or fall back to defaults #}
  {% for frequency in 'frequencies' | setting([{every:1,period:1},{every:2,period:2},{every:4,period:2}]) %}
    {% set frequency_days = frequency.every * frequency.period %}

    {# Adjust skip logic based on product.external_product_id #}
    {% if product.external_product_id == 12686486854 %}
      {# Skip frequencies with 30 days and 45 days for this specific product ID #}
      {% if frequency_days != 30 and frequency_days != 45 %}
        {% set frequency_text = 'frequency_period' | t(every = frequency.every, period = frequency.period) %}
        {% if frequency.every == subscription.every and frequency.period == subscription.every_period %}
          {% set subscription_frequency_still_exists = true %}
          <option selected value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% else %}
          <option value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% endif %}
      {% endif %}
    {% else %}
      {# Skip frequencies with 75 days and 90 days for all other products #}
      {% if frequency_days != 75 and frequency_days != 90 %}
        {% set frequency_text = 'frequency_period' | t(every = frequency.every, period = frequency.period) %}
        {% if frequency.every == subscription.every and frequency.period == subscription.every_period %}
          {% set subscription_frequency_still_exists = true %}
          <option selected value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% else %}
          <option value="{{ frequency.every }}_{{ frequency.period }}">{{ frequency_text }}</option>
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {# If an order still uses an old subscription value, keep it as an option. #}
  {% if not subscription_frequency_still_exists %}
    {% set old_frequency_text = 'frequency_period' | t(every = subscription.every, period = subscription.every_period) %}
    <option selected value="{{ subscription.every }}_{{ subscription.every_period }}" disabled>
      {{ old_frequency_text }}
    </option>
  {% endif %}
</select>

  </div>

  <input type="hidden" required name="subscription" value="{{subscription.public_id}}">
</form>
