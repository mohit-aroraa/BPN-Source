                  </svg>
                </div>
                <div class="shimmerStars__star">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 16">
                    <path fill="#EFEDED" d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256Z"/>
                  </svg>
                </div>
                <div class="shimmerStars__star">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 16">
                    <path fill="#EFEDED" d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256Z"/>
                  </svg>
                </div>
                <div class="shimmerStars__star">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 16">
                    <path fill="#EFEDED" d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256Z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="productTitle productTitle--shimmer animate"></div>
            <div class="price">
              <span class="animate"></span>
            </div>
            <div class="afterPay__shimmer animate"></div>
          </div>
          <p class="productServingText animate"></p>
          <p class="productShortDescription animate"></p>
          <div class="productOptions">
            <div class="productOptionSelectors">
              <div class="productOptionGroup">
                <div class="chooseVariant__label animate"></div>
                <div class="variantDropdown animate"></div>
                {%- if product.selling_plan_groups.size > 0 and widget_published == 'true' -%}
                  <div class="productPurchaseType">
                    <div class="rc_block rc_block--shimmer rc_block__type rc_block__type__autodeliver"></div>
                    <div class="rc_block rc_block--shimmer rc_block__type rc_block__type__onetime"></div>
                  </div>
                {%- endif -%}
                <div class="add-to-cart-btn shimmer">
                  <button type="button" class="button button-primary" disabled></button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
