      </div>
    </div>
    <div class="productTitle productTitle--shimmer animate"></div>
    <div class="price">
      <span class="animate"></span>
    </div>
    <div class="afterPay__shimmer animate"></div>
  </div>
  <div class="PDP__container">
    <div class="productSection__wrapper">
      <div class="productSection__left">
        <ol class="breadcrumbMain PDP__breadcrumb PDP__breadcrumb--desktop">
          <li class="animate"></li>
          <li class="animate"></li>
          <li class="animate"></li>
        </ol>
        <div class="productGallery">
          <div class="productGallery__thumbnailWrapper swiper">
            <div class="productGallery__thumbnailList productGallery__thumbnailList--shimmer swiper-wrapper">
              <div class="swiper-slide animate"></div>
              <div class="swiper-slide animate"></div>
              <div class="swiper-slide animate"></div>
              <div class="swiper-slide animate"></div>
              <div class="swiper-slide animate"></div>
            </div>
          </div>
          <div class="productGallery__swiper swiper">
            <div class="swiper-wrapper productGallery__swiperWrapper productGallery__swiperWrapper--shimmer">
              <div class="swiper-slide productGallery__slide animate"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="productSection__right">
        <div class="productSection__data">
          <div class="productSection__details--desktop">
            <div class="PDP__reviews PDP__reviews--desktop">
              <div class="shimmerStars">
                <div class="shimmerStars__star">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 16">
                    <path fill="#EFEDED" d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256Z"/>
