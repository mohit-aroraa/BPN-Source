
{% for block in section.blocks %}
  {% if block.type == 'left_image_right_content' %}
    <div class="image-content red-stripe-right texture-left">
      <div class="container">
        <div class="row">
          <div class="col-md-12 col-lg-6 order-1 order-lg-0">
            <img src="{{ block.settings.image | img_url: 'master'}}" alt="About Me" />
          </div>
          <div class="col-md-12 col-lg-6 order-0 order-lg-1">
            <div class="product-landing-content">
              <div class="section-title">
                <h2>{{ block.settings.title }}</h2>
              </div>
              <p>{{ block.settings.description }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  {% elsif block.type == 'right_image_left_content' %}
    <div class="image-content texture-right">
      <div class="container">
        <div class="row">
          <div class="col-md-12 col-lg-6 d-flex align-items-center flex-wrap">
            <div class="product-landing-content product-landing-content2">
              <div class="section-title-secondary">
                <h2>{{ block.settings.title1 }}</h2>
              </div>
              <p>{{ block.settings.description1 }}</p>
            </div>
          </div>
          <div class="col-md-12 col-lg-6">
            <img src="{{ block.settings.image1 | img_url: 'master' }}" alt="About Me" />
          </div>
        </div>
      </div>
    </div>
  {% endif %}
{% endfor %}