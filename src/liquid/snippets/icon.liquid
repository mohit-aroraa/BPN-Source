{%- capture icon_class -%} {{ class }} {%- endcapture -%}
{%- capture icon_click_id -%}{{ tag }}{%- endcapture -%}
{%- case icon -%}
  {% when 'header-close' %}
    <svg class='{{ icon_class }}' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 14'>
      <g stroke="#000" stroke-width="2" fill="none" fill-rule="evenodd" stroke-linecap="round"
         stroke-linejoin="round">
          <path d="m1.316 1.333 11.368 11.334M12.684 1.333 1.316 12.667"/>
      </g>
    </svg>

  {% when 'hamburger-close' %}
