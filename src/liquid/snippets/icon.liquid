      <path d="M1.4 14L0 12.6L5.6 7L0 1.4L1.4 0L7 5.6L12.6 0L14 1.4L8.4 7L14 12.6L12.6 14L7 8.4L1.4 14Z" fill="white"/>
    </svg>

  {% when 'hamburger' %}
    <svg class='{{ icon_class }}' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 17 14'>
      <g stroke="#000001" stroke-width="2" fill="none" fill-rule="evenodd" stroke-linecap="round"
         stroke-linejoin="round">
          <path d="M15.182 1.545H1M15.182 7H1M15.182 12.455H1"/>
      </g>
    </svg>
  {% when 'search' %}
