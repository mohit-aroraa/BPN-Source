{%- comment -%}
  This layout is used only on PLP, PDP, and Homepage
{%- endcomment -%}
<!doctype html>
<html class='no-js' lang='{{ shop.locale }}'>
  <head>
    {% comment %}<script async src="https://sdk.postscript.io/sdk.bundle.js?shopId=162246"></script>{% endcomment %}
    {% comment %} 1. Character Encodings {% endcomment %}
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge,chrome=1'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>

    {% comment %} Consent Mode + GTM Container (must load before all other scripts) {% endcomment %}
    {% render 'gcm-integration-script' %}
    {% render 'gtm-head' %}

    {% comment %} 2. Title {% endcomment %}
    {% include 'head-seo-title' %}
    <title>{{ seo_title | strip }}</title>
    {%- if page_description -%}
      <meta name='description' content='{{ page_description | escape }}'>
    {%- endif -%}

    {% comment %} 3. Preconnected Links {% endcomment %}
    {% render 'head-preconnect' %}

    {% comment %} 4. Synchronous Scripts {% endcomment %}
    {% include 'head-first-scripts' %}
    {% unless template contains 'page.athletic' %}
      <script
        async
        src='https://cdn.rebuyengine.com/onsite/js/rebuy.js?shop={{ shop.permanent_domain }}'
      ></script>
    {% endunless %}

    {% comment %} 5. Synchronous CSS {% endcomment %}
    {% render 'head-fonts' %}
    {% render 'css-variables' %}
    {% render 'style-bundle', layout: 'anatta_theme' %}

    {% comment %} 6. Preloaded Links {% endcomment %}

    {% comment %} 7. Asynchronous or deferred Scripts {% endcomment %}
    {%- if request.page_type contains 'customers/' -%}
      <script src='{{ 'shopify_common.js' | shopify_asset_url }}' defer='defer'></script>
    {%- endif -%}

    {%- if request.path contains '/pages/subscriptions' -%}
      <script src='https://cdn.tapcart.com/webbridge-sdk/webbridge.umd.js' defer></script>
    {%- endif -%}

    {% comment %} 8. Prefetched Links {% endcomment %}

    {% comment %} 9. Prerendered Links {% endcomment %}

    {% if page.title contains 'hidden'
      or template contains '404'
      or product.handle == 'bpn-x-ciele-endurance-cap-black'
    %}
      <meta name='robots' content='noindex'>
    {% endif %}

    {% if template == 'product' and product.handle == 'bpn-x-rhone-black-hat' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {% if template == 'product' and product.handle == 'bpn-x-rhone-black-tee' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {% if template == 'product' and product.handle == 'bpn-x-rhone-olive-3-short' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {% if template == 'product' and product.handle == 'bpn-x-rhone-black-3-short' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {% if template contains 'collection' and collection.handle == 'bpn-x-rhone' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}

    {% comment %} 10. Non-rendering assets {% endcomment %}
    {% if page.title contains 'hidden' %}
      <meta name='robots' content='noindex'>
    {% endif %}
    {% render 'tv-squared' %}
    <link rel='canonical' href='{{ canonical_url }}'>
    {% comment %} Meta Data for Octane Quiz Cache {% endcomment %}
    {%- if template contains 'quiz' -%}
      <meta http-equiv='cache-control' content='no-cache'>
      <meta http-equiv='expires' content='0'>
      <meta http-equiv='pragma' content='no-cache'>
    {% endif %}
    {% render 'head-track-element' %}
    {% render 'head-favicon' %}
    {% render 'head-social-meta-tags' %}
    {%- if content_for_header contains 'previewBarInjector.init();' -%}
      {% render 'console-logs' %}
    {%- endif -%}
    <script>
      document.documentElement.className = document.documentElement.className.replace(
        'no-js',
        'js'
      );
    </script>
    <meta name='facebook-domain-verification' content='am3mtk47tbu8ze8vo8228en0f8o1kn'>
    {{ content_for_header }}
    {% render 'customer-data' %}
    {% render 'interstitial-config' %}
    {% render 'microsoft-clarity-script' %}
    <script async="true" src="https://app.lightlabs.com/assets/ll-pip-widget-v5.js"></script>
    <script async="true" src="https://app.lightlabs.com/assets/ll-pip-sticker.js"></script>
  </head>
  <body class='{% render "body-class" %}'>
    {% comment %} Edgemesh Server: Dynamic Data {% endcomment %}
    <dynamic>
      {% render 'gtm-body' %}
      {% render 'gtm-data-layer-user-data' %}
    </dynamic>
    {% render 'gtm-data-layer' %}
    {% render 'vwo' %}
    {% render 'toast' %}
    {% render 'bpn-init' %}
    {% render 'sms-subscription-modal' %}
    {% render 'cart' %}
    {% render 'product-drawer' %}
    {% render 'global-theme-variables' %}
    <div role='complementary' id='skip-to-main-container'>
      <a class='in-page-link visually-hidden skip-link' href='#MainContent'>
        {{- 'general.accessibility.skip_to_content' | t -}}
      </a>
    </div>
    <div class='wrapper'>
      <header class='pageHeader header__wrapper'>
        {% sections 'header-group' %}
      </header>
      <main class='mid-container' id='MainContent' tabindex='-1'>
        {{ content_for_layout }}
      </main>
      {% render 'free-shipping-promo-script' %}
      {% sections 'footer-group' %}
    </div>
    {% unless template contains 'page.preview' %}
      {% include 'global-prismic-settings' %}
    {% endunless %}
    <div class='div-tooltip'></div>
    {% render 'accelerated-checkout-buttons' %}
    {% include 'footer-crazy-egg' %}
    {%- if template contains 'quiz' -%}
      <script src='https://app.octaneai.com/bsg3u3ljo4kplzuf/shopify.js' async defer></script>
    {%- endif -%}
    <script
      type='text/javascript'
      async
      data-em-load='afterInteractive'
      src='https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=WXXxWk'
    ></script>
    {% render 'audioeye-script' %}
    {% render 'script-bundle', layout: 'anatta_theme' %}
    <script src='{{ 'instantpage.js' | asset_url }}' async defer type='text/javascript'></script>
  </body>
</html>
