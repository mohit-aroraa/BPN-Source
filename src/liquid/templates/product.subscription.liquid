{%- layout none -%}

{%- assign allow_subscriptions = product.metafields.custom.allow_subscriptions -%}

{%- assign _has_matching_plans = false -%}
{%- for spg in product.selling_plan_groups -%}
  {%- if settings.subscription_platform == 'skio' and spg.app_id == 'SKIO' -%}
    {%- assign _has_matching_plans = true -%}{%- break -%}
  {%- elsif settings.subscription_platform != 'skio' and spg.app_id != 'SKIO' -%}
    {%- assign _has_matching_plans = true -%}{%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- capture jsonExample -%}
  {
  "id": {{ product.id }},
  "handle": "{{ product.handle }}",
  "requires_selling_plan": {{ product.requires_selling_plan }},
  {%- capture _spg_json -%}[{%- assign _is_first = true -%}{%- assign _valid_group_ids = '' -%}{%- for spg in product.selling_plan_groups -%}{%- if settings.subscription_platform == 'skio' and spg.app_id != 'SKIO' -%}{%- continue -%}{%- endif -%}{%- if settings.subscription_platform != 'skio' and spg.app_id == 'SKIO' -%}{%- continue -%}{%- endif -%}{%- assign _valid_group_ids = _valid_group_ids | append: spg.id | append: '|' -%}{%- unless _is_first -%},{%- endunless -%}{%- assign _is_first = false -%}{{ spg | json }}{%- endfor -%}]{%- endcapture -%}
  "selling_plan_groups": {{ _spg_json }},
  "tags": {{ product.tags | json }},
  "allow_subscriptions": {% if allow_subscriptions == false %}false{% elsif _has_matching_plans %}true{% else %}false{% endif %},
  "variants": {
  {% for variant in product.variants %}
    {% assign size = variant.title | split: "/" | last | strip %}
    "{{ variant.title }}": {
    "id": "{{ variant.id }}",
    "variant_option_index": {{ forloop.index0 }},
    "selling_plan_allocations": [
    {%- assign _alloc_first = true -%}
    {% for allocation in variant.selling_plan_allocations %}
      {%- unless _valid_group_ids contains allocation.selling_plan_group_id -%}{%- continue -%}{%- endunless -%}
      {%- unless _alloc_first -%},{%- endunless -%}{%- assign _alloc_first = false -%}
      {
      "price_adjustments": [
      {% for price_adjustment in allocation %}
        {
        "position": {{ price_adjustment.position }},
        "price": {{ price_adjustment.price }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
      ],
      "price": {{ allocation.price }},
      "compare_at_price": {{ allocation.compare_at_price }},
      "per_delivery_price": {{ allocation.per_delivery_price }},
      "selling_plan_id": {{ allocation.selling_plan.id }},
      "selling_plan_group_id": "{{ allocation.selling_plan_group_id }}"
      }
    {% endfor %}
    ]
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  }
  }
{% endcapture %}

{{ jsonExample | strip }}
