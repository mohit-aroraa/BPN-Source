    "faq_jajCx3": {
      "type": "faq",
      "blocks": {
        "slide_4iBXHM": {
          "type": "Slide",
          "settings": {
            "title": "What makes G.1.M Sport superior?",
            "text": "G.1.M Sport utilizes a specific carbohydrate source called Cluster Dextrin®, far superior to other sources on the market for athletes. Compared to glucose, Cluster Dextrin® has a high molecular weight and low osmotic pressure, leading to fast gastric emptying and reducing the risk of gastrointestinal distress."
          }
        },
        "slide_UNzi6C": {
          "type": "Slide",
          "settings": {
            "title": "When and how to use G.1.M Sport?",
            "text": "Add one scoop of G.1.M Sport to 15-20 oz of water and mix. To start, consume one serving per hour of exercise to refuel, replenish, and rehydrate. Depending on your training methods, volume, and intensity of workouts, you can increase your servings per hour to maximize performance benefits. G.1.M Sport can be used before, during, or after training."
          }
        },
        "slide_B6eC8Y": {
          "type": "Slide",
          "settings": {
            "title": "Is G.1.M Sport Gluten Free?",
            "text": "Yes, G.1.M Sport is a gluten free product. We test every batch to ensure our quality standards. **According to the Food and Drug Administration (FDA) a product is considered \"gluten free\" as long as it contains less than 20 parts per million (ppm) of gluten."
          }
        },
        "slide_nFG7zH": {
          "type": "Slide",
          "settings": {
            "title": "IS G.1.M Sport THIRD-PARTY TESTED FOR BANNED SUBSTANCES?",
            "text": "Yes, G.1.M Sport is enrolled in NSF's Certified for Sport® Program. In addition to testing for over 290+ athletic banned substances, products bearing the Certified for Sport® mark on package must be produced in a manufacturing facility that complies with cGMP requirements. If you use a BPN product that bears the NSF Certified for Sport® mark, you can be confident that its contents were thoroughly tested by one of the most respected certifiers in the world."
          }
        },
        "slide_kkYTLR": {
          "type": "Slide",
          "settings": {
            "title": "Does BPN Test For Label Accuracy?",
            "text": "All BPN products are enrolled in the NSF Contents Certified Certification Program. The product and label are tested to verify product formulation and label claims, to be sure that what’s on the label is in the product. Chemical and contaminant testing is also conducted to make sure there are no potentially harmful levels of specific contaminants, pesticides, heavy metals, and more. In addition, a toxicological review of the label is performed to make sure all ingredients are allowed to be used in a product and that the amount of each ingredient does not exceed typical use levels established by NSF."
          }
        },
        "slide_d7Fakq": {
          "type": "Slide",
          "settings": {
