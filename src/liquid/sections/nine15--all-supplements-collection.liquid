<!-- sections/nine15--all-supplements-collection -->

{% include 'master--custom-collection' %}

{% schema %}
{
    "name": "Collection pages",
    "settings": [
        {
            "type": "range",
            "id": "grid",
            "label": "Products per row (grid only)",
            "default": 4,
            "min": 2,
            "max": 5,
            "step": 1
        },
        {
            "type": "range",
            "id": "rows",
            "label": "Rows per page (grid only)",
            "default": 2,
            "min": 1,
            "max": 8,
            "step": 1
        }
    ],
    "blocks": [
        {
            "name": "Collection",
            "type": "collection",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title"
                },
                {
                    "type": "text",
                    "id": "anchor",
                    "label": "Anchor Title"
                },
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Collection"
                }
            ]
        }
    ]
}
{% endschema %}
