    },
    {
      "id": "mobile_button_url",
      "type": "url",
      "label": "Mobile Button URL"
    },
    {
      "type": "header",
      "content": "Buttons - Desktop"
    },
    {
      "id": "desktop_button_option",
      "type": "select",
      "label": "Desktop Button Option",
      "options": [
        { "value": "secondary", "label": "Secondary" },
        { "value": "primary", "label": "Primary" }
      ],
      "default": "primary"
    },
    {
      "id": "desktop_button_text",
      "type": "text",
      "label": "Desktop Button Text",
      "default": "Shop Now"
    },
    {
      "id": "desktop_button_url",
      "type": "url",
      "label": "Desktop Button URL"
    }
  ],
  "presets": [
    {
      "name": "Athletic Two Column",
      "category": "Athletic Landing Pages"
    }
  ]
}
{% endschema %}
