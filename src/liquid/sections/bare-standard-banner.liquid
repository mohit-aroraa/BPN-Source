
<div class="hero-section animation-img">
  {% comment %}
  <div class="anim__image-swipe anim__image-swipe--up">	
  	<div class="hero-bg"></div>
  </div>  
  <div class="container text-center wow fadeInUp">
    <div class="bare-standerd-logo">
      <img src="{{ 'bpn-logo.svg'| asset_url }}">	
    </div>
    {% assign title1 = section.settings.title | slice: 0, 4  %}
    {% assign title2 = section.settings.title | slice: 4, 5  %}
    {% assign title3 = section.settings.title | slice: 8, 12  %}
    <h1>{{title1}} <span>{{title2}}</span> <span> {{title3}} </span></h1>

    <a class="btn btn-primary" href="{{section.settings.video_button_link}}" role="button">{{section.settings.video_button_text}}</a>
  </div>
  {% endcomment %}
  
  <div class="sim-slider-slide">
    <video onloadedmetadata="this = true" autobuffer autoplay muted loop playsinline >
      <source src="{{section.settings.slide_video1}}" >
    </video>
    <div class="video-link-wrapper">
      <a class="btn btn-primary" href="javascript:void(0)" data-toggle="modal" data-target="#exampleModal">{{section.settings.video_button_text}}</a>
    </div>
    <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-video-wrapper" role="document">
        <div class="modal-content">
          <div class="modal-body" id="modal-body">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
           <video onloadedmetadata="this = true" autobuffer controls {% comment %}autoplay muted loop playsinline{% endcomment %} >
              <source src="{{section.settings.slide_video1}}" >
            </video>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script type="text/javascript">
     $(function(){
        var clickPolice = false,
            vidLnk = '.video-link-wrapper a',
            clsLnk = '.modal-body .close', 
            vidEmb = '#exampleModal video';
        // start video
        $(vidLnk).on('click touch',function(){
            if ( $(vidEmb).length > 0 ) {
                $(vidEmb).get(0).play()
            }
            clickPolice = true;
            setTimeout(function() { clickPolice = false; }, 500);
        });
        // stop video when close modal with X
        $(clsLnk).on('click touch',function(){
            if ( $(vidEmb).length > 0 ) {
                $(vidEmb).get(0).load()
            }
        });
        // stop video when closing modal by click background
        window.addEventListener('click', function(e){ 
          if (!clickPolice) {  //clickPolice prevents this function from stopping video before it can start
            if (!document.getElementById('modal-body').contains(e.target)){
              if ( $(vidEmb).length > 0 ) {
                  $(vidEmb).get(0).load() 
              }
            }
          }
        });
    });
  </script>
</div>
{% schema %}
  {
    "name": "Bare Standard video",
    "settings": [
    {
      "type": "text",
      "id": "slide_video1",
      "label": "mp4 video link"
    },
	{
      "id": "video_button_text",
      "type": "text",
      "label": "Video button text"
	}
	]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
<style>
  .hero-bg{
    background-image:url({{section.settings.banner_image | img_url: 'master'}}); 

  }
</style>