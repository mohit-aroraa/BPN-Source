{% liquid
	assign curURL 		= canonical_url | split: '.com' | last
	assign curTYP 		= template
	assign pageFound 	= false
	assign fallbackHero = ''
%}
<!-- 
    sections/page-heros 
    current template: {{curTYP}} 
    current url: {{curURL}} 
-->
{% for block in section.blocks %}
    {% liquid 
    	assign b 		= block.settings
	    assign pageUrl 	= b.page_url
	    assign pageType = b.page_type
    %}
    {% comment %}<!--
        Block ID: {{block.id}}
        Block Title: {{b.title}}
        {% if pageUrl != blank %}Block Url: {{pageUrl}}{% endif %} 
        {% if pageType != blank %}Block Type: {{pageType}}{% endif %} 
    --> {% endcomment %}
    {% comment %} Check for exact match {% endcomment %}
    {% if curURL != blank %}
        {% if curURL == pageUrl %}
            <!-- {{curURL}} == {{pageUrl}} -->
            {% assign pageFound = true %}
            {% include 'master--page-heros' %}
            {% break %}
        {% endif %}
        {% comment %} Check for similar match {% endcomment %}
        {% if current_tags and curURL contains pageUrl and pageFound == false %}
            <!-- {{curURL}} contains {{pageUrl}} -->
            {% capture fallbackHero %}
                {% include 'master--page-heros' %}
            {% endcapture %}
        {% endif %}
    {% endif %}
    {% comment %} Check for default {% endcomment %}
    {% if pageFound == false and fallbackHero == '' %}
        {% if curTYP == pageType %}
            <!-- {{curTYP}} == {{pageType}} -->
            {% capture fallbackHero %}
                {% include 'master--page-heros' %}
            {% endcapture %}
        {% endif %}
    {% endif %}
    {% comment %} If no exact match then use fallback {% endcomment %}
    {% if forloop.last == true and pageFound == false and fallbackHero != '' %}
        {{fallbackHero}}
    {% endif %}
{% endfor %}

{% comment %}{
                            "type": "select",
                            "id": "btn_style",
                            "label": "Button Type",
                            "options": [
                                {
                                    "value": "primary",
                                    "label": "Primary"
                                },
                                {
                                    "value": "secondary",
                                    "label": "Secondary"
                                },
                                {
                                    "value": "tertiary",
                                    "label": "Tertiary"
                                }
                            ],
                            "default": "primary"
                        },{% endcomment %}

{% schema %}
    {
        "name": "Page Heros",
        "settings": [
            {
                "type": "paragraph",
                "content": "Works on any Collection, Page, Product, Article, or Blog!"
            }            
        ],
        "blocks": [
            {
                "name": "Hero",
                "type": "hero",
                "settings": [
                    {
                        "type":"header",
                        "content": "Display Settings"
                    },
                        {
                            "type": "text",
                            "id": "title",
                            "label": "Tab Title",
