                            "placeholder": "Alt Collection (Default)"
                        },
                        {
                            "type":"paragraph",
                            "content": "If you want this hero to appear on every page of a certain template then type that in the select box below. If a page using this template is also assigned an additional Specific Page then that takes precedence."
                        },
                        {
                            "type": "text",
                            "id": "page_type",
                            "label": "All content with this Template (default)",
                            "info": "Type out the template type you want this to be the default hero for.",
                            "placeholder": "collection.alternate"
                        },
                        {
                            "type":"paragraph",
                            "content": "If you want this hero to appear on a specific page then find that page in the select box below. This Hero will be applied ONLY on that page and will overwrite any Default Heros."
                        },
                        {
                            "type": "url",
                            "id": "page_url",
                            "label": "Specific Page",
                            "info": "Select the page you want the Hero to appear on."
                        },
                        
                    {
                        "type":"header",
                        "content": "Image Settings"
                    },
                        {
                            "type": "checkbox",
                            "id": "allow_default",
                            "label": "Allow default image to show.",
                            "info": "If using as Template Default, checking this allows Default Image from page to take precedance. Only using below images when needed."
                        },
                        {
                            "type": "image_picker",
                            "id": "image",
                            "label": "Hero Image"
                        },
                        {
                            "type": "select",
                            "id": "align_bg",
                            "label": "Background Alignment (Focal Point)",
                            "options": [
                                {
                                    "value": "center",
                                    "label": "Center"
                                },
                                {
                                    "value": "left center",
                                    "label": "Left Center"
                                },
                                {
                                    "value": "center right",
                                    "label": "Right Center"
                                },
                                {
                                    "value": "top center",
                                    "label": "Center Top"
                                },
                                {
                                    "value": "top left",
                                    "label": "Left Top"
                                },
                                {
                                    "value": "top right",
                                    "label": "Right Top"
                                },
                                {
                                    "value": "bottom center",
                                    "label": "Center Bottom"
                                },
                                {
                                    "value": "bottom left",
                                    "label": "Left Bottom"
                                },
                                {
                                    "value": "bottom right",
                                    "label": "Right Bottom"
                                }
                            ],
                            "default": "center"
                        },
                        {
                            "type": "select",
                            "id": "bg_size",
                            "label": "Background Size",
                            "options": [
                                {
                                    "value": "cover",
                                    "label": "Cover"
                                },
                                {
                                    "value": "contain",
                                    "label": "Contain"
                                },
                                {
                                    "value": "custom",
                                    "label": "Custom"
                                }
                                
