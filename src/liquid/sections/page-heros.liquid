                                },
                                {
                                    "value": "left center",
                                    "label": "Left Center"
                                },
                                {
                                    "value": "center right",
                                    "label": "Right Center"
                                },
                                {
                                    "value": "top center",
                                    "label": "Center Top"
                                },
                                {
                                    "value": "top left",
                                    "label": "Left Top"
                                },
                                {
                                    "value": "top right",
