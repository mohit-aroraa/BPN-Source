          "label": "Nav Link Text"
        },
        {
          "id": "menu_nav_url",
          "type": "url",
          "label": "Nav Link Url"
        },
        {
          "id": "navigation",
          "type": "link_list",
          "label": "Navigation"
        },
        {
          "type": "header",
          "content": "Button Area"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button Url"
        },
        {
          "type": "header",
          "content": "Activity Section First"
        },
        {
          "type": "image_picker",
          "id": "activity_image_first",
          "label": "Activity Image"
        },
        {
          "type": "text",
          "id": "activity_text_first",
          "label": "Activity Text"
        },
        {
          "type": "text",
          "id": "activity_cta_text_first",
          "label": "Activity CTA Text"
        },
        {
          "type": "url",
          "id": "activity_cta_url_first",
          "label": "Activity CTA Url"
        },
        {
          "type": "header",
          "content": "Activity Section Second"
        },
        {
          "type": "image_picker",
          "id": "activity_image_second",
          "label": "Activity Image"
        },
        {
          "type": "text",
          "id": "activity_text_second",
          "label": "Activity Text"
        },
        {
          "type": "text",
          "id": "activity_cta_text_second",
          "label": "Activity CTA Text"
        },
        {
          "type": "url",
          "id": "activity_cta_url_second",
          "label": "Activity CTA Url"
        },
        {
          "type": "header",
          "content": "Activity Section Third"
        },
        {
          "type": "image_picker",
          "id": "activity_image_third",
          "label": "Activity Image"
        },
        {
          "type": "text",
          "id": "activity_text_third",
          "label": "Activity Text"
        },
        {
          "type": "text",
          "id": "activity_cta_text_third",
          "label": "Activity CTA Text"
        },
        {
          "type": "url",
          "id": "activity_cta_url_third",
          "label": "Activity CTA Url"
        }
      ]
    },
    {
      "type": "single_link",
      "name": "Single Link",
      "settings": [
        {
          "id": "nav_link",
          "type": "text",
          "label": "Nav Link"
        },
        {
          "id": "nav_link_url",
          "type": "url",
          "label": "Nav Link Url"
        }
      ]
    },
    {
      "type": "mobiletablink",
      "name": "Mobile Tab Links",
      "settings": [
        {
          "id": "mobile_nav_text",
          "type": "text",
          "label": "Nav Link Text"
        },
        {
          "id": "mobile_nav_url",
          "type": "url",
          "label": "Nav Link Url"
        },
        {
          "id": "mobile_nav_color",
          "type": "color",
          "label": "Nav Link Background",
          "default": "#dcff00"
        }
      ]
    }
  ]
}
