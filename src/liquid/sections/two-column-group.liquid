{%- assign _section = section.settings -%}
<section class='bpn-tile-group'>
  {% if _section.title != blank %}
    <h2 class='bpn-tile-group__title bpn-text-h3' style='color: {{ _section.title_color }}'>
      {{ _section.title }}
      {% if _section.subtitle != blank -%}
        <span class='bpn-tile-group__title-highlight' style='color: {{ _section.subtitle_color }}'>
          {{- _section.subtitle -}}
        </span>
      {%- endif %}
    </h2>
  {% endif %}

  <div class='bpn-tile-group__container'>
    {% for block in section.blocks %}
      {%- assign _block = block.settings -%}
      {% capture ext_link %}{% if _block.tile_url contains 'https://' or _block.tile_url contains 'http://' or _block.tile_url contains '#' %}{{_block.tile_url}}{% else %}{{shop.url}}{{_block.tile_url}}{%   endif %}{% endcapture %}

      <a
        class='bpn-tile bpn-tile--long'
        href='{{ ext_link }}'
        {% if ext_link contains shop.url %}
        {% else %}
          target='_blank'
          rel='noopener'
        {% endif %}
        data-click-id='{{ _block.click_id }}'
        aria-label='{{ _block.tile_title }}'
      >
        {% if _block.tile_img_url != blank %}
          {{
            _block.tile_img_url
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'bpn-tile__image',
              alt: _block.tile_title,
              width: 900,
              height: 950
          }}
        {% endif %}

        <div class='bpn-tile__content'>
          <div class='bpn-tile__content-wrapper'>
            {% if _block.tile_title != blank %}
              <h3
                class='bpn-tile__title bpn-text-title-1-large'
                data-click-id='{{ _block.click_id }}'
                style='color: {{ _block.tile_title_color }}'
              >
                {{ _block.tile_title }}
              </h3>
            {% endif %}
            {% if _block.tile_text != blank %}
              <p
                class='bpn-tile__text bpn-text-body-base'
                data-click-id='{{ _block.click_id }}'
                style='color: {{ _block.tile_text_color }}'
              >
                {{ _block.tile_text }}
              </p>
            {% endif %}
          </div>
          <div class='bpn-tile__link-container'>
            <span class='bpn-tile__link'>
              {% render 'icon', icon: 'white-left-arrow', tag: _block.click_id %}
            </span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Two Column Tile Group",
  "settings": [
    {
      "type": "header",
      "content": "Title Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Section Title Color"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Section Subtitle Color"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "text",
          "id": "tile_title",
          "label": "Tile Title"
        },
        {
          "type": "color",
          "id": "tile_title_color",
          "label": "Tile Title Color"
        },
        {
          "type": "textarea",
          "id": "tile_text",
          "label": "Tile Text"
        },
        {
          "type": "color",
          "id": "tile_text_color",
          "label": "Tile Text Color"
        },
        {
          "type": "header",
          "content": "Link Settings"
        },
        {
          "type": "url",
          "id": "tile_url",
          "label": "Tile URL"
        },
        {
          "type": "text",
          "id": "click_id",
          "label": "Click ID"
        },
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "image_picker",
          "id": "tile_img_url",
          "label": "Tile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Two Column Tile Group",
      "category": "Custom"
    }
  ]
}
{% endschema %}
