      "default": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "previous_discount_percentage",
      "label": "Previous Discount Percentage"
    },
    {
      "type": "text",
      "id": "subscription_discount_text",
      "label": "Subscription Discount text"
    },
    {
      "type": "text",
      "id": "subscription_text",
