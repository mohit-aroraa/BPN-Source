      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_order_by",
      "label": "Show order by?",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_copy_text",
      "label": "Show copy text?",
      "default": true
