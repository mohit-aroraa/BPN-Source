        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "packs",
      "name": "Pack Option Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "number",
          "id": "num_boxes",
          "label": "Number of Boxes",
          "default": 1
        },
        {
          "type": "number",
          "id": "discount_pct",
          "label": "Discount %",
