        },
        {
          "type": "checkbox",
          "id": "most_popular",
          "label": "Most Popular",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "best_deal",
          "label": "Best Deal",
          "default": false
        }
      ]
    },
    {
      "type": "badge",
      "name": "Badge item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
