{% comment %}
  Main Collection Section
  ====================
  This section displays the collection products, filters and pagination
{% endcomment %}

{% liquid
  assign has_sidebar = false
  for block in section.blocks
    if block.type == 'sidebar'
      assign has_sidebar = true
      assign sidebar_block = block
      break
    endif
  endfor
  assign products_per_page = 30
  assign promo_image_position = 3
%}

<section
  class='bpn-collection{% if section.settings.class %} {{ section.settings.class }}{% endif %}'
  data-collection-handle='{{ collection.handle }}'
  data-collection-id='{{ collection.id }}'
>
  {% paginate collection.products by products_per_page %}
    <div class='bpn-collection__header'>
      <div class='bpn-collection__breadcrumb'>
        <a class='bpn-collection__breadcrumb-link' href='/'>Home</a>
        /<a class='bpn-collection__breadcrumb-link' href='/collections/all'>Shop All</a>
        {% if collection.handle != 'all' %}
          /<a class='bpn-collection__breadcrumb-link' href='{{ collection.url }}'>
            {{ collection.title -}}
          </a>
        {% endif %}
      </div>

      <h1 class='bpn-collection__title'>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class='bpn-collection__description'>{{ collection.description }}</div>
      {% endif %}
    </div>

    {% render 'collection-navigation' %}

    <div class='bpn-collection__controls'>

    {% if collection.filters.size > 0 %}
      <div class='bpn-collection__product-filter-label'>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='12'
          viewBox='0 0 20 12'
          fill='none'
        >
          <g clip-path="url(#clip0_4177_8527)">
            <path
              d="M0 0.852273C0 0.381818 0.430769 0 0.961538 0H19.0385C19.2935 0 19.538 0.0897928 19.7184 0.249625C19.8987 0.409457 20 0.626236 20 0.852273C20 1.07831 19.8987 1.29509 19.7184 1.45492C19.538 1.61475 19.2935 1.70455 19.0385 1.70455H0.961538C0.430769 1.70455 0 1.32273 0 0.852273ZM3.07692 5.625C3.07692 5.15455 3.50769 4.77273 4.03846 4.77273H15.9615C16.2166 4.77273 16.4611 4.86252 16.6414 5.02235C16.8218 5.18218 16.9231 5.39896 16.9231 5.625C16.9231 5.85104 16.8218 6.06782 16.6414 6.22765C16.4611 6.38748 16.2166 6.47727 15.9615 6.47727H4.03846C3.50769 6.47727 3.07692 6.09545 3.07692 5.625ZM7.11539 9.54545C6.86037 9.54545 6.6158 9.63525 6.43547 9.79508C6.25515 9.95491 6.15385 10.1717 6.15385 10.3977C6.15385 10.6238 6.25515 10.8405 6.43547 11.0004C6.6158 11.1602 6.86037 11.25 7.11539 11.25H12.8846C13.1396 11.25 13.3842 11.1602 13.5645 11.0004C13.7449 10.8405 13.8462 10.6238 13.8462 10.3977C13.8462 10.1717 13.7449 9.95491 13.5645 9.79508C13.3842 9.63525 13.1396 9.54545 12.8846 9.54545H7.11539Z"
              fill="black" />
          </g>
          <defs>
            <clipPath id="clip0_4177_8527">
              <rect width="20" height="12" fill="white" />
            </clipPath>
          </defs>
        </svg>

        <span>{{ 'collections.general.filters' | t }}</span>
      </div>
    {% endif %}
      <div class='bpn-collection__product-count filtered-product-count'>
        {% if collection.products_count > 0 %}
          {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
        {% else %}
          {{ 'collections.general.no_matches' | t }}
        {% endif %}
      </div>

      {% if has_sidebar and collection.filters.size > 0 %}
        <button class='bpn-collection__filter-trigger'>
          <div>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='16'
              height='9'
              viewBox='0 0 16 9'
              fill='none'
            >
              <path
                d="M0 0.681818C0 0.305455 0.344615 0 0.769231 0H15.2308C15.4348 0 15.6304 0.0718342 15.7747 0.1997C15.919 0.327566 16 0.500989 16 0.681818C16 0.862648 15.919 1.03607 15.7747 1.16394C15.6304 1.2918 15.4348 1.36364 15.2308 1.36364H0.769231C0.344615 1.36364 0 1.05818 0 0.681818ZM2.46154 4.5C2.46154 4.12364 2.80615 3.81818 3.23077 3.81818H12.7692C12.9732 3.81818 13.1689 3.89002 13.3132 4.01788C13.4574 4.14575 13.5385 4.31917 13.5385 4.5C13.5385 4.68083 13.4574 4.85425 13.3132 4.98212C13.1689 5.10998 12.9732 5.18182 12.7692 5.18182H3.23077C2.80615 5.18182 2.46154 4.87636 2.46154 4.5ZM5.69231 7.63636C5.4883 7.63636 5.29264 7.7082 5.14838 7.83606C5.00412 7.96393 4.92308 8.13735 4.92308 8.31818C4.92308 8.49901 5.00412 8.67243 5.14838 8.8003C5.29264 8.92817 5.4883 9 5.69231 9H10.3077C10.5117 9 10.7074 8.92817 10.8516 8.8003C10.9959 8.67243 11.0769 8.49901 11.0769 8.31818C11.0769 8.13735 10.9959 7.96393 10.8516 7.83606C10.7074 7.7082 10.5117 7.63636 10.3077 7.63636H5.69231Z"
                fill="black" />
            </svg>
            FILTER
          </div>
          <div class='bpn-collection__filter-trigger-item-count'>
            <span class='filtered-product-count'>
              {% if collection.products_count > 0 %}
                {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
              {% else %}
                {{ 'collections.general.no_matches' | t }}
              {% endif %}
            </span>

            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='6'
              height='12'
              viewBox='0 0 6 12'
              fill='none'
            >
              <path fill-rule="evenodd" clip-rule="evenodd"
                    d="M0.175736 0.181315C0.41005 -0.0604383 0.789949 -0.0604383 1.02426 0.181315L5.82426 5.13369C6.05858 5.37545 6.05858 5.76741 5.82426 6.00916L1.02426 10.9615C0.789949 11.2033 0.41005 11.2033 0.175736 10.9615C-0.0585786 10.7198 -0.0585786 10.3278 0.175736 10.0861L4.55147 5.57143L0.175736 1.05678C-0.0585786 0.815027 -0.0585786 0.423068 0.175736 0.181315Z"
                    fill="black" />
            </svg>
          </div>
        </button>
      {% endif %}

      <div class='bpn-collection__sort'>
        <label for='SortBy' class='bpn-collection__sort-label'> Sort By </label>
        <select
          data-label='{{ 'collections.sorting.label' | t }}'
          id='SortBy'
          name='sort_by'
          class='bpn-collection__sort-select'
        >
          <option value='manual'>
            {{ 'collections.sorting.featured' | t }}
          </option>
          <option value='best-selling'>
            {{ 'collections.sorting.best_selling' | t }}
          </option>
          <option value='title-ascending'>
            {{ 'collections.sorting.az' | t }}
          </option>
          <option value='title-descending'>
            {{ 'collections.sorting.za' | t }}
          </option>
          <option value='price-ascending'>
            {{ 'collections.sorting.price_ascending' | t }}
          </option>
          <option value='price-descending'>
            {{ 'collections.sorting.price_descending' | t }}
          </option>
          <option value='created-descending'>
            {{ 'collections.sorting.date_descending' | t }}
          </option>
          <option value='created-ascending'>
            {{ 'collections.sorting.date_ascending' | t }}
          </option>
        </select>
      </div>
    </div>

    <div class='bpn-collection__content'>
      {% if has_sidebar and collection.filters.size > 1 %}
        <div class='bpn-collection__sidebar'>
          <div class='bpn-collection__sidebar-header'>
            <h6 class='bpn-collection__sidebar-title'>
              {{ 'collections.general.filters' | t }}
            </h6>

            <button class='bpn-collection__sidebar-close-button'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='16'
                height='16'
                viewBox='0 0 16 16'
                fill='none'
              >
                <rect width="16" height="16" fill="white" />
                <path d="M1.6 16L0 14.4L6.4 8L0 1.6L1.6 0L8 6.4L14.4 0L16 1.6L9.6 8L16 14.4L14.4 16L8 9.6L1.6 16Z"
                      fill="black" />
              </svg>
            </button>
          </div>
          <div class='bpn-collection__sidebar-filter'>
            <div class='bpn-collection__filter'>
              {%- render 'facets',
                results: collection,
                filter_type: 'vertical',
                show_count: sidebar_block.settings.show_filter_count,
                open_by_default: sidebar_block.settings.open_filters_by_default
              -%}
            </div>
          </div>
          <div class='bpn-collection__sidebar-footer'>
            <a
              class='bpn-collection__sidebar-footer-button secondary-button'
              href='{{ collection.url }}'
              >CLEAR ALL</a
            >
            <a
              class='bpn-collection__sidebar-footer-button primary-button'
              href='{{ collection.url }}'
              >APPLY</a
            >
          </div>
        </div>
      {% endif %}

      <main class='bpn-collection__main'>
        {% if has_sidebar %}
          <div class='bpn-facets__active-filter'>
            {% assign has_active_filter = false %}

            {%- for filter in collection.filters -%}
              {%- for value in filter.values -%}
                {%- assign active_value = false -%}
                {%- for active_filter in filter.active_values -%}
                  {%- if value.handle == active_filter.handle -%}
                    {%- assign active_value = true -%}
                    {%- assign has_active_filter = true -%}
                  {%- endif -%}
                {%- endfor -%}

                <div class='bpn-facets__active-filter-item{% if active_value %} active{% endif %}'>
                  {{ value.label }}

                  <button
                    class='bpn-facets__active-filter-button'
                    data-name='{{ value.param_name }}'
                    data-value='{{ value.value }}'
                  >
                    {% render 'bpn-icon', icon: 'filter-cross-icon' %}
                  </button>
                </div>
              {% endfor %}
            {% endfor %}

            <button class='bpn-facets__active-filter-clear-button{% if has_active_filter == true %} active{% endif %}'>
              CLEAR ALL
            </button>
          </div>
        {% endif %}
        {%- for block in section.blocks -%}
          {%- if block.type == 'callout' -%}
            <div class="bpn-collection__callout-wrapper">
              {%- render 'strength-collection-callout', source: block -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        <div class='bpn-collection__product-grid'>
          <div class='bpn-collection__products{% if has_sidebar %} bpn-collection__products--with-sidebar{% endif %} {%if collection.filters.size < 1%} col-4 {% endif %}'>
            <div class='bpn-collection__products-inner'>
              {% if collection.products.size == 0 %}
                <div class='bpn-collection__empty'>
                  <p>{{ 'collections.general.no_matches' | t }}</p>
                </div>
              {% else %}
              {% comment %} {% assign gwp_settings = shop.metaobjects.gwp['settings'] %}
                {% if gwp_settings.enable_timer %}
                  <div>
                    {% render 'bfcm-offer-banner' , fixed:false %}
                  </div>
                {% endif %}
              {% endcomment %}
                {% for product in collection.products %}
                  {%- assign product_index = forloop.index -%}
                  {% if product_index == promo_image_position
                    and section.settings.show_promo_card
                  %}
                    {% if section.settings.promo_card_type == 'image' %}
                      <div
                        data-product-handle='promotion'
                        data-product-position='{{ promo_image_position |  minus: 1 }}'
                        class='bpn-collection__promo-image {% if section.settings.promo_image_class %} {{ section.settings.promo_image_class }}{% endif %}'
                      >
                        <a
                          href='{{ section.settings.promo_image_link }}'
                          class='bpn-collection__promo-image-link'
                        >
                          <div
                            class='bpn-collection__promo-image-wrapper'
                            style='--desktop-image: url({{ section.settings.promo_image | image_url: width: 1000 }}); --mobile-image: url({% if section.settings.promo_image_mobile != blank %}{{ section.settings.promo_image_mobile | image_url: width: 900 }}{% else %}{{ section.settings.promo_image | image_url: width: 900 }}{% endif %});'
                            role='img'
                            aria-label='{{ section.settings.promo_image.alt | escape |  default: "Promotional Image" }}'
                          ></div>
                        </a>
                      </div>
                    {% elsif section.settings.promo_card_type == 'video' %}
                      <div
                        data-product-handle='promotion'
                        data-product-position='{{ promo_image_position |  minus: 1 }}'
                        class='bpn-collection__promo-video {% if section.settings.promo_image_class %} {{ section.settings.promo_image_class }}{% endif %}'
                      >
                        <a
                          href='{{ section.settings.promo_image_link }}'
                          class='bpn-collection__promo-video-link'
                          aria-label='Promotional video'
                        >
                          {% if section.settings.promo_video != blank %}
                            <div class='bpn-collection__promo-video-desktop'>
                              {{
                                section.settings.promo_video
                                | video_tag:
                                  image_size: '1000x',
                                  autoplay: true,
                                  loop: true,
                                  muted: true,
                                  controls: false,
                                  playsinline: true,
                                  class: 'bpn-collection__promo-video-element'
                              }}
                            </div>
                          {% endif %}
                          {% if section.settings.promo_video_mobile != blank %}
                            <div class='bpn-collection__promo-video-mobile'>
                              {{
                                section.settings.promo_video_mobile
                                | video_tag:
                                  image_size: '900x',
                                  autoplay: true,
                                  loop: true,
                                  muted: true,
                                  controls: false,
                                  playsinline: true,
                                  class: 'bpn-collection__promo-video-element'
                              }}
                            </div>
                          {% endif %}
                        </a>
                      </div>
                    {% endif %}
                  {% endif %}
                  {% render 'product-grid', product: product, index: product_index %}
                {% endfor %}
              {% endif %}
            </div>
          </div>
          {% if paginate.pages > 1 %}
            <div class='bpn-collection__pagination'>
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        </div>
      </main>
    </div>
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "text",
      "id": "class",
      "label": "Additional CSS class"
    },
    {
      "type": "header",
      "content": "Filtering and Sorting"
    },
    {
      "type": "header",
      "content": "Promo Card"
    },
    {
      "type": "checkbox",
      "id": "show_promo_card",
      "label": "Show Promo card",
      "default": false
    },
    {
      "type": "select",
      "label": "Promo Card Media Type",
      "id": "promo_card_type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        { "value": "video", "label": "Video" }
      ]
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promotional image (Desktop)",
      "info": "Recommended aspect ratio: 5:7 with 50px side margins",
      "visible_if": "{{ section.settings.show_promo_card and section.settings.promo_card_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "promo_image_mobile",
      "label": "Promotional image (Mobile)",
      "info": "Recommended aspect ratio: 3:5 with 70px side margins",
      "visible_if": "{{ section.settings.show_promo_card and section.settings.promo_card_type == 'image' }}"
    },
    {
      "type": "video",
      "id": "promo_video",
      "label": "Promo Video (Desktop)",
      "info": "Recommended aspect ratio: 5:7",
      "visible_if": "{{ section.settings.show_promo_card and section.settings.promo_card_type == 'video' }}"
    },
    {
      "type": "video",
      "id": "promo_video_mobile",
      "label": "Promo Video (Mobile)",
      "info": "Recommended aspect ratio: 3:5",
      "visible_if": "{{ section.settings.show_promo_card and section.settings.promo_card_type == 'video' }}"
    },
    {
      "type": "url",
      "id": "promo_image_link",
      "label": "Image/Video link",
      "visible_if": "{{ section.settings.show_promo_card }}"
    },
    {
      "type": "text",
      "id": "promo_image_class",
      "label": "Additional CSS class for promo image"
    }
  ],
  "blocks": [
    {
      "type": "sidebar",
      "name": "Sidebar Filters",
      "limit": 1
    },
    {
      "type": "callout",
      "name": "Collection Callout",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Featured product"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image (overrides product image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (overrides product title)",
          "default": "STRENGTH COLLECTION"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "PRE + PUMP + POST"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "promo_text",
          "label": "Promo banner text",
          "default": "STRENGTH COLLECTION OUT NOW // SAVE 25% + FREE SHIPPING"
        },
        {
          "type": "url",
          "id": "learn_more_url",
          "label": "Learn more URL"
        },
        {
          "type": "text",
          "id": "learn_more_label",
          "label": "Learn more label",
          "default": "LEARN MORE"
        },
        {
          "type": "url",
          "id": "pdp_url",
          "label": "SELECT FLAVORS URL",
          "info": "Leave blank to use the selected product URL"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SELECT FLAVORS"
        },
        {
          "type": "text",
          "id": "savings_text",
          "label": "Savings callout text",
          "default": "SAVE 25% + FREE Shipping (US)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Page",
      "category": "Collection"
    }
  ]
}
{% endschema %}
