<!-- sections/nine15--blog-feed -->

{% include 'master--blog-feed--paginate' %}

    <!-- "class": "index-section index-section--flush", -->
{% schema %}
{
    "name": "Blog Feed",
    "settings": [
        {
            "type":"blog",
            "id":"blog",
            "label":"Blog",
            "info": "If you add blocks then this is ignored."
        },
        {
            "type":"text",
            "id":"title",
            "label":"Title",
            "info": "Will show blog title if left blank."
        },
        {
            "type":"richtext",
            "id":"text",
            "label":"Text"
        },
        {
            "type":"checkbox",
            "id":"hide_desc",
            "label":"Hide description",
            "default": false
        },
        {
            "type":"header",
            "content": "Row Setting"
        },
        {
            "type":      "range",
            "id":        "total_rows",
            "min":       1,
            "max":       10,
            "step":      1,
            "label":     "Total rows on Desktop",
            "default":   1,
            "info": "Will be ignored if blocks used."
        },
        {
            "type":      "range",
            "id":        "per_row",
            "min":       0,
            "max":       5,
            "step":      1,
            "label":     "Articles per row",
            "default":   3
        },
        {
            "type":"header",
            "content": "Section title link"
        },
        {
            "type":"paragraph",
            "content": "Only applies when blocks are used."
        },
        {
            "type":"text",
            "id":"link_text",
            "label":"Link Text"
        },
        {
            "type":"url",
            "id":"link_url",
            "label":"Link Url"
        },
        {
            "type":"header",
            "content": "Custom CSS Rules"
        },
        {
            "type":"paragraph",
            "content": "Explanation of Custom CSS rules below input."
        },
        {
            "type": "html",
            "id": "custom_css",
            "label": "Custom CSS"
        },
        {
            "type":"paragraph",
            "content": "Use '==' to reference this block's parent container, that way the css you use only applies to this container. The example below applies font size to only the h2 element in the current block's container."
        },
        {
            "type":"paragraph",
            "content": "Ex: '== h2 { font-size: 20px; }'"
        },
        {
            "type":"paragraph",
            "content": "Use '/MEDIA_QUERY/' to create media queries that match css defaults. The example below would output '@media screen and (max-width: 749px)' before the css."
        },
        {
            "type":"paragraph",
            "content": "Ex: '/small/ { == h2 { font-size: 20px; } }'"
        },
        {
            "type":"paragraph",
            "content": "Media Queries: narrow, not-narrow, small, medium, medium-up, medium-down, large, large-up, large-down, ex-large, ex-large-up, ex-large-down, widescreen"
        }
    ],
    "blocks": [
        {
            "type":"article",
            "name":"Article",
            "settings":[
                {
                    "type":"article",
                    "id":"article",
                    "label":"Article"
                },
                {
                    "type":"header",
                    "content": "Optional Overrides"
                },
                {
                    "type":"image_picker",
                    "id":"image",
                    "label":"Image"
                },
                {
                    "type":"text",
                    "id":"title",
                    "label":"Title"
                },
                {
                    "type":"text",
                    "id":"date",
                    "label":"Date"
                },
                {
                    "type":"textarea",
                    "id":"text",
                    "label":"Text"
                }
            ]
        }
    ]
}
{% endschema %}

