#!/usr/bin/env bash
set -e

# =============================================================================
# Sync Production Settings
# =============================================================================
# Pulls JSON settings files from the production theme and commits them to git.
# Run this before creating a release PR to capture the current production state.
#
# Usage:
#   bin/sync-production-settings              # Interactive mode
#   bin/sync-production-settings --commit     # Auto-commit changes
#   bin/sync-production-settings --dry-run    # Show what would be pulled
#
# Environment variables:
#   PROD_STORE     - Production store URL (default: bare-performance-nutrition.myshopify.com)
#   PROD_THEME_ID  - Production theme ID (required, or set in .env)
# =============================================================================

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
PROD_STORE="${PROD_STORE:-bare-performance-nutrition.myshopify.com}"
PROD_THEME_ID="${PROD_THEME_ID:-}"

# Parse arguments
AUTO_COMMIT=false
DRY_RUN=false

for arg in "$@"; do
  case $arg in
    --commit)
      AUTO_COMMIT=true
      ;;
    --dry-run)
      DRY_RUN=true
      ;;
    --help|-h)
      echo "Usage: bin/sync-production-settings [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --commit    Automatically commit changes after pulling"
      echo "  --dry-run   Show what would be pulled without making changes"
      echo "  --help      Show this help message"
      echo ""
      echo "Environment variables:"
      echo "  PROD_STORE     Production store URL"
      echo "  PROD_THEME_ID  Production theme ID (required)"
      exit 0
      ;;
  esac
done

# Load .env if it exists
if [ -f .env ]; then
  # shellcheck disable=SC1091
  source .env
fi

# Check for required theme ID
if [ -z "$PROD_THEME_ID" ]; then
  echo -e "${RED}❌ PROD_THEME_ID is not set${NC}"
  echo ""
  echo "Set it in one of these ways:"
  echo "  1. Add PROD_THEME_ID=123456789 to your .env file"
  echo "  2. Run: PROD_THEME_ID=123456789 bin/sync-production-settings"
  echo ""
  echo "To find your production theme ID:"
  echo "  Go to Shopify Admin → Online Store → Themes → ... → Edit code"
  echo "  The ID is in the URL: /themes/THEME_ID/editor"
  exit 1
fi

# Check for Shopify CLI
if ! command -v shopify &> /dev/null; then
  echo -e "${RED}❌ Shopify CLI is not installed${NC}"
  echo "Run: npm install -g @shopify/cli@latest"
  exit 1
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Sync Production Settings${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "  Store:    ${GREEN}$PROD_STORE${NC}"
echo -e "  Theme ID: ${GREEN}$PROD_THEME_ID${NC}"
echo ""

if [ "$DRY_RUN" = true ]; then
  echo -e "${YELLOW}🔍 Dry run mode - no changes will be made${NC}"
  echo ""
  echo "Would pull the following files from production:"
  echo "  - config/settings_data.json"
  echo "  - templates/*.json"
  echo "  - sections/*.json"
  exit 0
fi

# Create directories if they don't exist
mkdir -p src/config
mkdir -p dist/config

echo -e "${BLUE}📥 Pulling settings from production...${NC}"
echo ""

# Pull to a temp directory first to avoid Shopify CLI's "up to date" skipping behavior
# When pulling to a directory with existing files, it may skip files it thinks haven't changed
TEMP_DIR=$(mktemp -d)
trap 'rm -rf '"$TEMP_DIR" EXIT

# Pull JSON files from production
shopify theme pull \
  --store "$PROD_STORE" \
  --theme "$PROD_THEME_ID" \
  --only "config/settings_data.json" \
  --only "templates/*.json" \
  --only "sections/*.json" \
  --path "$TEMP_DIR"

# Copy pulled files to dist/
echo ""
echo -e "${BLUE}📦 Copying to dist/...${NC}"
if [ -d "$TEMP_DIR/config" ]; then
  mkdir -p dist/config
  cp -r "$TEMP_DIR/config/"* dist/config/ 2>/dev/null || true
fi
if [ -d "$TEMP_DIR/templates" ]; then
  mkdir -p dist/templates
  cp -r "$TEMP_DIR/templates/"*.json dist/templates/ 2>/dev/null || true
fi
if [ -d "$TEMP_DIR/sections" ]; then
  mkdir -p dist/sections
  cp -r "$TEMP_DIR/sections/"*.json dist/sections/ 2>/dev/null || true
fi

echo ""
echo -e "${BLUE}📁 Copying to src/ for version control...${NC}"

# Copy settings_data.json to src/config/
if [ -f "dist/config/settings_data.json" ]; then
  cp dist/config/settings_data.json src/config/
  echo "  ✓ config/settings_data.json"
fi

# Copy template JSONs to src/liquid/templates/
template_count=0
for f in dist/templates/*.json; do
  if [ -f "$f" ]; then
    cp "$f" src/liquid/templates/
    template_count=$((template_count + 1))
  fi
done
if [ $template_count -gt 0 ]; then
  echo "  ✓ $template_count template JSON file(s)"
fi

# Copy section JSONs to src/liquid/sections/
section_count=0
for f in dist/sections/*.json; do
  if [ -f "$f" ]; then
    cp "$f" src/liquid/sections/
    section_count=$((section_count + 1))
  fi
done
if [ $section_count -gt 0 ]; then
  echo "  ✓ $section_count section JSON file(s)"
fi

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Changes Detected${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Show git diff summary
if git diff --quiet src/; then
  echo -e "${GREEN}✓ No changes detected - production settings match the repo${NC}"
  exit 0
fi

git diff --stat src/

echo ""

if [ "$AUTO_COMMIT" = true ]; then
  echo -e "${BLUE}📝 Committing changes...${NC}"

  # Add synced files explicitly (only if they exist)
  git add -A src/config/settings_data.json 2>/dev/null || true
  git add -A src/liquid/templates/*.json 2>/dev/null || true
  git add -A src/liquid/sections/*.json 2>/dev/null || true

  # Verify something was staged before committing
  if ! git diff --cached --quiet; then
    git commit -m "chore: sync production settings (pre-release)

Pulled from: $PROD_STORE
Theme ID: $PROD_THEME_ID
Date: $(date -u +"%Y-%m-%d %H:%M:%S UTC")"
    echo ""
    echo -e "${GREEN}✓ Changes committed${NC}"
  else
    echo -e "${YELLOW}⚠️  No files were staged for commit${NC}"
  fi
else
  echo -e "${YELLOW}Review the changes above, then run:${NC}"
  echo ""
  echo "  git add src/config/settings_data.json src/liquid/templates/*.json src/liquid/sections/*.json"
  echo "  git commit -m 'chore: sync production settings (pre-release)'"
  echo ""
  echo -e "Or re-run with ${GREEN}--commit${NC} to auto-commit:"
  echo "  bin/sync-production-settings --commit"
fi

echo ""
echo -e "${GREEN}✅ Sync complete!${NC}"

