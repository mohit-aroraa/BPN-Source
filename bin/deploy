#!/usr/bin/env bash
set -e

# =============================================================================
# Deploy to Development Theme
# =============================================================================
# Builds and pushes the theme to your personal dev theme on the staging store.
# Uses STORE_URL and THEME_ID from your .env file.
#
# Usage:
#   bin/deploy              # Build and deploy
#   yarn deploy             # Same thing via yarn
#
# For CI/CD deployments to staging/preview/production, use GitHub Actions.
# =============================================================================

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Load .env if it exists
if [ -f .env ]; then
  # shellcheck disable=SC1091
  source .env
fi

# Set defaults
STORE_URL="${STORE_URL:-dev-bare-performance-nutrition.myshopify.com}"

# Check for required theme ID
if [ -z "$THEME_ID" ]; then
  echo -e "${RED}❌ THEME_ID is not set${NC}"
  echo ""
  echo "Set it in one of these ways:"
  echo "  1. Add THEME_ID=123456789 to your .env file"
  echo "  2. Run: yarn create-dev-theme"
  echo ""
  echo "To find your theme ID:"
  echo "  Go to Shopify Admin → Online Store → Themes → ... → Edit code"
  echo "  The ID is in the URL: /themes/THEME_ID/editor"
  exit 1
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Deploy to Development Theme${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "  Store:    ${GREEN}$STORE_URL${NC}"
echo -e "  Theme ID: ${GREEN}$THEME_ID${NC}"
echo ""

# Build
echo -e "${BLUE}📦 Building theme...${NC}"
npm run build

echo ""
echo -e "${BLUE}🚀 Deploying to theme...${NC}"
echo ""

# Deploy
shopify theme push \
  --path dist \
  --store "$STORE_URL" \
  --theme "$THEME_ID" \
  --nodelete

echo ""
echo -e "${GREEN}✅ Deploy complete!${NC}"
echo ""
echo -e "Preview: ${BLUE}https://${STORE_URL}/?preview_theme_id=${THEME_ID}${NC}"

